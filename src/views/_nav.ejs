  <div class="nav-tabs">
    <a href="/notes" class="nav-tab <%= active === 'notes' ? 'active' : '' %>">Anılar</a>
    <a href="/daily" class="nav-tab <%= active === 'daily' ? 'active' : '' %>">Günlük</a>
    <a href="/goals" class="nav-tab <%= active === 'goals' ? 'active' : '' %>">Hedefler</a>
    <a href="/personal" class="nav-tab <%= active === 'personal' ? 'active' : '' %>">Yunus'dan Not</a>
