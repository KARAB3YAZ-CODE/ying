<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
  <title>Ying - Gizem ve Yunus Aşkı</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="browse-page">
    <%- include('_nav', { member: member, photo: photo, active: 'love' }) %>

    <div class="browse-content daily-content">
      <section class="daily-status-card">
        <h3>💛 Gizem ve Yunus Aşkı</h3>
        <% if (revealed) { %>
        <p class="goal-status-open">🔓 Açıldı — herkesin mesajı aşağıda.</p>
        <% } else { %>
        <p>Aşağıdaki başlıklara sırayla birer mesaj yaz. Sadece Yunus ve Gizem onaylayınca hepsi birden herkese açılacak.</p>

        <div class="daily-today">
          <span class="daily-today-label">Onay (Yunus &amp; Gizem)</span>
          <div class="daily-votes">
            <% approvers.forEach(function(a) { %>
            <span class="daily-vote-chip <%= votes.includes(a) ? 'voted' : '' %>"><%= a %><%= votes.includes(a) ? ' ✓' : '' %></span>
            <% }) %>
          </div>
          <% if (canVote) { %>
          <form method="POST" action="/love/vote">
            <button type="submit" class="hero-btn hero-btn-primary">
              <%= votes.includes(member) ? 'Onayımı geri al' : ('Onayla ve aç (' + votes.length + '/2)') %>
            </button>
          </form>
          <% } %>
        </div>
        <% } %>
      </section>

      <% categories.forEach(function(cat) { %>
      <section class="goal-category">
        <div class="goal-category-header">
          <h3><%= cat.label %></h3>
        </div>

        <% if (revealed) { %>
          <% if (cat.entries.length === 0) { %>
          <p class="goal-empty">Bu başlığa kimse yazmadı.</p>
          <% } else { %>
          <div class="goal-entries">
            <% cat.entries.forEach(function(e) { %>
            <div class="goal-entry">
              <span class="goal-entry-author"><%= e.author %></span>
              <p class="goal-entry-text"><%= e.content %></p>
            </div>
            <% }) %>
          </div>
          <% } %>
        <% } else { %>
          <div class="daily-votes">
            <% config.members.forEach(function(m) { %>
            <span class="daily-vote-chip <%= cat.writtenBy.includes(m.name) ? 'voted' : '' %>"><%= m.name %><%= cat.writtenBy.includes(m.name) ? ' ✓' : '' %></span>
            <% }) %>
          </div>

          <% if (cat.alreadyWrote) { %>
          <p class="goal-locked-msg">✓ Bu başlığa yazdın, kilitlendi.</p>
          <% } else { %>
          <form method="POST" action="/love" class="goal-form" onsubmit="return confirm('Bu notu kaydettikten sonra değiştiremez ya da silemezsin. Eklemek istediğin başka bir şey var mı? Emin misin?');">
            <textarea name="content" placeholder="<%= cat.label %>" class="goal-textarea" required></textarea>
            <input type="hidden" name="category" value="<%= cat.key %>">
            <button type="submit" class="hero-btn hero-btn-primary">Yaz ve kilitle</button>
          </form>
          <% } %>
        <% } %>
      </section>
      <% }) %>
    </div>
  </div>

  <script>
    (function() {
      var nav = document.getElementById('topNav');
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            nav.classList.toggle('scrolled', window.scrollY > 10);
            ticking = false;
          });
          ticking = true;
        }
      });
    })();

    // live sync: reload when someone else writes or approval status changes
    (function() {
      var lastStatus = null;
      setInterval(function() {
        if (document.hidden) return;
        fetch('/love/status').then(function(r) { return r.json(); }).then(function(data) {
          var s = JSON.stringify(data);
          if (lastStatus === null) { lastStatus = s; return; }
          if (s !== lastStatus) location.reload();
        }).catch(function() {});
      }, 5000);
    })();
  </script>
</body>
</html>
