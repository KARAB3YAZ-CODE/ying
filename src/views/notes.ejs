<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ying - Anılar</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="browse-page">
    <nav class="top-nav" id="topNav">
      <div class="nav-brand">Ying</div>
      <div class="nav-right">
        <div class="nav-user">
          <div class="nav-avatar" style="background: linear-gradient(135deg, <%= member === 'Yunus' ? '#e50914,#b20710' : member === 'İrem' ? '#e87c03,#b85d00' : member === 'Nursene' ? '#5fa33e,#3d7a23' : '#0080ff,#0052b3' %>);<%= photo ? ' background-image: url(' + photo + '); background-size: cover; background-position: center;' : '' %>">
            <span class="avatar-initial"><%= member[0] %></span>
          </div>
          <span><%= member %></span>
        </div>
        <form method="POST" action="/logout" style="display:inline">
          <button type="submit" class="btn-nav">Çıkış</button>
        </form>
      </div>
    </nav>

    <!-- HERO -->
    <% if (notes.length > 0) { %>
    <% var hero = notes[0]; %>
    <% var heroType = hero.photo ? hero.content ? 'Fotoğraflı Not' : 'Fotoğraf' : 'Not'; %>
    <div class="hero-section" style="<%= hero.photo ? 'background-image: url(' + hero.photo + ')' : 'background: linear-gradient(135deg, #1f1f1f, #2a2a2a)' %>">
      <div class="hero-gradient"></div>
      <div class="hero-vignette"></div>
      <div class="hero-content">
        <div class="hero-badge-group">
          <span class="hero-badge">En Son</span>
          <span class="hero-badge hero-badge-type"><%= heroType %></span>
          <% if (hero.content && hero.content.length > 80) { %><span class="hero-badge hero-badge-long">Uzun Anı</span><% } %>
        </div>
        <h2 class="hero-title"><%= hero.content ? hero.content.slice(0, 80) : '📷 Bir Fotoğraf' %></h2>
        <% if (hero.content && hero.content.length > 80) { %>
        <p class="hero-desc"><%= hero.content.slice(0, 200) %><% if (hero.content.length > 200) { %>…<% } %></p>
        <% } %>
        <div class="hero-meta">
          <span class="hero-year"><%= new Date(hero.createdAt).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          <span class="hero-dot">·</span>
          <span class="hero-author"><%= hero.author %></span>
        </div>
        <div class="hero-actions">
          <button class="hero-btn hero-btn-primary" onclick="openNote('<%= hero.id %>')">▶ Anıyı Aç</button>
          <button class="hero-btn hero-btn-secondary" onclick="document.querySelector('.compose-input').focus();">+ Yeni Anı</button>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="hero-section hero-empty" style="background: linear-gradient(135deg, #1a1a1a, #0d0d0d)">
      <div class="hero-gradient"></div>
      <div class="hero-vignette"></div>
      <div class="hero-content">
        <div class="hero-badge-group">
          <span class="hero-badge">Hoş Geldin</span>
        </div>
        <h2 class="hero-title">Henüz anın yok</h2>
        <p class="hero-desc">İlk anını yaz veya bir fotoğraf yükle — burası senin özel anılar koleksiyonun.</p>
        <div class="hero-actions">
          <button class="hero-btn hero-btn-primary" onclick="document.querySelector('.compose-input').focus();">+ İlk Anını Oluştur</button>
        </div>
      </div>
    </div>
    <% } %>

    <div class="browse-content">
      <!-- COMPOSE BAR -->
      <div class="compose-bar">
        <form method="POST" action="/notes" enctype="multipart/form-data" class="compose-form">
          <input name="content" placeholder="Ne düşünüyorsun?" class="compose-input">
          <label class="compose-photo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <input type="file" name="photo" accept="image/*" onchange="this.form.submit()">
          </label>
          <button type="submit" class="compose-btn">Gönder</button>
        </form>
      </div>

      <!-- ROW: Tüm Anılar -->
      <section class="row">
        <div class="row-header">
          <h3>Tüm Anılar</h3>
          <% if (notes.length > 0) { %><a href="#" class="row-seeall" onclick="document.querySelector('#row-all').scrollLeft = 0; return false;">Tümünü Gör</a><% } %>
        </div>
        <% if (notes.length === 0) { %>
        <div class="row-empty">Henüz anın yok</div>
        <% } else { %>
        <div class="row-scroll" id="row-all">
          <% notes.forEach(function(note) { %>
          <div class="card" onclick="openNote('<%= note.id %>')">
            <div class="card-art" style="<%= note.photo ? 'background-image: url(' + note.photo + ')' : 'background: linear-gradient(135deg, #2a2a2a, #1f1f1f)' %>">
              <% if (!note.photo) { %>
              <div class="card-noimg"><%= note.content ? note.content[0].toUpperCase() : '📝' %></div>
              <% } %>
              <div class="card-hover">
                <span class="card-hover-title"><%= note.content ? note.content.slice(0, 50) : '📷 Fotoğraf' %></span>
                <span class="card-hover-date"><%= new Date(note.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) %></span>
              </div>
              <div class="card-bottom">
                <span class="card-bottom-title"><%= note.content ? note.content.slice(0, 50) : '📷 Fotoğraf' %></span>
                <span class="card-bottom-author"><%= note.author %></span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </section>

      <!-- ROW: Fotoğraflar -->
      <% var photos = notes.filter(function(n) { return n.photo; }); %>
      <% if (photos.length > 0) { %>
      <section class="row">
        <div class="row-header">
          <h3>Fotoğraflar</h3>
          <a href="#" class="row-seeall" onclick="document.querySelector('#row-photos').scrollLeft = 0; return false;">Tümünü Gör</a>
        </div>
        <div class="row-scroll" id="row-photos">
          <% photos.forEach(function(note) { %>
          <div class="card" onclick="openNote('<%= note.id %>')">
            <div class="card-art" style="background-image: url(<%= note.photo %>)">
              <div class="card-hover">
                <span class="card-hover-title"><%= note.content ? note.content.slice(0, 50) : '📷 Fotoğraf' %></span>
                <span class="card-hover-date"><%= new Date(note.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) %></span>
              </div>
              <div class="card-bottom">
                <span class="card-bottom-title"><%= note.content ? note.content.slice(0, 50) : '📷 Fotoğraf' %></span>
                <span class="card-bottom-author"><%= note.author %></span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- ROW: Notlar -->
      <% var textNotes = notes.filter(function(n) { return !n.photo; }); %>
      <% if (textNotes.length > 0) { %>
      <section class="row">
        <div class="row-header">
          <h3>Notlar</h3>
          <a href="#" class="row-seeall" onclick="document.querySelector('#row-text').scrollLeft = 0; return false;">Tümünü Gör</a>
        </div>
        <div class="row-scroll" id="row-text">
          <% textNotes.forEach(function(note) { %>
          <div class="card" onclick="openNote('<%= note.id %>')">
            <div class="card-art" style="background: linear-gradient(135deg, <%= note.author === 'Yunus' ? '#e50914' : note.author === 'İrem' ? '#e87c03' : note.author === 'Nursene' ? '#5fa33e' : '#0080ff' %>22, #1a1a1a)">
              <div class="card-noimg" style="font-size:1.6rem"><%= note.content ? note.content.slice(0, 1).toUpperCase() : '📝' %></div>
              <div class="card-hover">
                <span class="card-hover-title"><%= note.content ? note.content.slice(0, 50) : 'Not' %></span>
                <span class="card-hover-date"><%= new Date(note.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' }) %></span>
              </div>
              <div class="card-bottom">
                <span class="card-bottom-title"><%= note.content ? note.content.slice(0, 50) : 'Not' %></span>
                <span class="card-bottom-author"><%= note.author %></span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>
    </div>
  </div>

  <!-- NOTE MODAL -->
  <div class="note-overlay" id="noteOverlay">
    <div class="note-preview" id="notePreview"></div>
  </div>

  <script>
    var notesData = <%- JSON.stringify(notes).replace(/</g, '\\u003c') %>;
    var currentMember = <%- JSON.stringify(member).replace(/</g, '\\u003c') %>;

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function(ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
      });
    }

    function openNote(id) {
      var note = notesData.find(function(n) { return n.id === id; });
      if (!note) return;
      var overlay = document.getElementById('noteOverlay');
      var preview = document.getElementById('notePreview');

      var html = '<div class="note-preview-top">';
      html += '<button class="note-preview-close" onclick="closeNote()">✕</button>';
      html += '<span class="note-preview-author">' + escapeHtml(note.author) + '</span>';
      var d = new Date(note.createdAt);
      html += '<span class="note-preview-date">' + d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) + '</span>';
      html += '</div>';
      if (note.photo) {
        html += '<img src="' + escapeHtml(note.photo) + '" class="note-preview-img">';
      }
      if (note.content) {
        html += '<div class="note-preview-text">' + escapeHtml(note.content) + '</div>';
      }
      if (note.author === currentMember) {
        html += '<form method="POST" action="/notes/delete/' + encodeURIComponent(note.id) + '" class="note-preview-del"><button type="submit">Sil</button></form>';
      }

      preview.innerHTML = html;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeNote() {
      document.getElementById('noteOverlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    document.getElementById('noteOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeNote();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeNote();
    });

    (function() {
      var nav = document.getElementById('topNav');
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            nav.classList.toggle('scrolled', window.scrollY > 10);
            ticking = false;
          });
          ticking = true;
        }
      });
    })();
  </script>
</body>
</html>
