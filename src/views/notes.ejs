<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ying - Notlar</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="notes-page">
    <nav class="top-nav" id="topNav">
      <div class="nav-brand">Ying</div>
      <div class="nav-right">
        <div class="nav-user">
          <div class="nav-avatar" style="background: linear-gradient(135deg, <%= member === 'Yunus' ? '#e50914,#b20710' : member === 'İrem' ? '#e87c03,#b85d00' : member === 'Nursene' ? '#5fa33e,#3d7a23' : '#0080ff,#0052b3' %>);<%= photo ? ' background-image: url(' + photo + '); background-size: cover; background-position: center;' : '' %>">
            <span class="avatar-initial" style="font-size:14px"><%= member[0] %></span>
          </div>
          <span><%= member %></span>
        </div>
        <form method="POST" action="/logout" style="display:inline">
          <button type="submit" class="btn-nav">Çıkış</button>
        </form>
      </div>
    </nav>

    <div class="content-area">
      <h2 class="section-title">Notlar</h2>

      <div class="compose-card">
        <form method="POST" action="/notes" enctype="multipart/form-data">
          <textarea name="content" placeholder="Ne düşünüyorsun?" rows="2"></textarea>
          <div class="compose-actions">
            <label class="photo-label">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              Fotoğraf
              <input type="file" name="photo" accept="image/*" onchange="this.form.submit()">
            </label>
            <button type="submit" class="btn-submit">Paylaş</button>
          </div>
        </form>
      </div>



      <% if (notes.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
          </div>
          <p>Henüz notun yok</p>
          <span>İlk notu yaz veya bir fotoğraf yükle</span>
        </div>
      <% } %>

      <% notes.forEach(function(note) { %>
        <div class="entry">
          <div class="entry-inner">
            <div class="entry-meta">
              <span class="entry-date"><%= new Date(note.createdAt).toLocaleString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
              <form method="POST" action="/notes/delete/<%= note.id %>" style="display:inline">
                <button type="submit" class="btn-entry-del">Sil</button>
              </form>
            </div>
            <% if (note.content) { %>
              <div class="entry-text"><%= note.content %></div>
            <% } %>
          </div>
          <% if (note.photo) { %>
            <img src="<%= note.photo %>" class="entry-photo" alt="fotoğraf" loading="lazy">
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>

  <script>
    (function() {
      var nav = document.getElementById('topNav');
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            if (window.scrollY > 10) {
              nav.classList.add('scrolled');
            } else {
              nav.classList.remove('scrolled');
            }
            ticking = false;
          });
          ticking = true;
        }
      });
    })();
  </script>
</body>
</html>
