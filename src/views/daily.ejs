<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet">
  <title>Ying - Günlük</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="browse-page">
    <%- include('_nav', { member: member, photo: photo, active: 'daily' }) %>

    <div class="browse-content daily-content">
      <section class="daily-status-card">
        <h3>📖 Günlük</h3>
        <% if (canWrite) { %>
          <p>Günlüğe yazma sırası sende — yeni bir giriş ekleyebilirsin.</p>
        <% } else { %>
          <p>Sıradaki günlük girişine kalan süre:</p>
          <div class="daily-countdown" id="countdown">
            <span id="cd-hours">00</span><span class="cd-sep">:</span>
            <span id="cd-minutes">00</span><span class="cd-sep">:</span>
            <span id="cd-seconds">00</span>
          </div>
          <p class="daily-who-wrote">Son yazan: <strong><%= lastEntryAuthor %></strong></p>
        <% } %>
      </section>

      <% if (canWrite) { %>
      <div class="compose-bar">
        <form method="POST" action="/daily" enctype="multipart/form-data" class="compose-form">
          <input name="content" placeholder="Bugün ne oldu?" class="compose-input">
          <label class="compose-photo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <input type="file" name="photo" accept="image/*" onchange="this.form.submit()">
          </label>
          <button type="submit" class="compose-btn">Ekle</button>
        </form>
      </div>
      <% } %>

      <% if (entries.length === 0) { %>
      <div class="row-empty">Henüz hiç günlük girişi yok — ilk girişi sen yap</div>
      <% } else { %>
      <section class="row">
        <div class="row-header"><h3>Geçmiş Günlükler</h3></div>
        <% groupedEntries.forEach(function(group) { %>
        <h4 class="daily-date-header"><%= group.label %></h4>
        <div class="row-scroll">
          <% group.items.forEach(function(note) { %>
          <div class="card" onclick="openDaily('<%= note.id %>')">
            <div class="card-art" style="<%= note.photo ? 'background-image: url(' + note.photo + ')' : 'background: linear-gradient(135deg, #2a2a2a, #1f1f1f)' %>">
              <% if (!note.photo) { %>
              <div class="card-noimg"><%= note.content ? note.content[0].toUpperCase() : '📝' %></div>
              <% } %>
              <div class="card-bottom">
                <span class="card-bottom-title"><%= note.content ? note.content.slice(0, 50) : '📷 Fotoğraf' %></span>
                <span class="card-bottom-author"><%= note.author %></span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% }) %>
      </section>
      <% } %>
    </div>
  </div>

  <div class="note-overlay" id="noteOverlay">
    <div class="note-preview" id="notePreview"></div>
  </div>

  <script>
    var entriesData = <%- JSON.stringify(entries).replace(/</g, '\\u003c') %>;
    var msLeft = <%- msLeft %>;

    (function() {
      var cdEl = document.getElementById('countdown');
      if (!cdEl) return;

      var hEl = document.getElementById('cd-hours');
      var mEl = document.getElementById('cd-minutes');
      var sEl = document.getElementById('cd-seconds');

      function pad(n) { return String(n).padStart(2, '0'); }

      function tick() {
        msLeft = Math.max(0, msLeft - 1000);
        var totalSec = Math.floor(msLeft / 1000);
        var h = Math.floor(totalSec / 3600);
        var m = Math.floor((totalSec % 3600) / 60);
        var s = totalSec % 60;
        hEl.textContent = pad(h);
        mEl.textContent = pad(m);
        sEl.textContent = pad(s);
        if (msLeft <= 0) location.reload();
      }

      setInterval(tick, 1000);
    })();

    // live sync
    (function() {
      var last = null;
      setInterval(function() {
        if (document.hidden) return;
        fetch('/daily/status').then(function(r) { return r.json(); }).then(function(d) {
          var s = JSON.stringify(d);
          if (last === null) { last = s; return; }
          if (s !== last) location.reload();
        }).catch(function() {});
      }, 5000);
    })();

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, function(ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
      });
    }

    function openDaily(id) {
      var note = entriesData.find(function(n) { return n.id === id; });
      if (!note) return;
      var overlay = document.getElementById('noteOverlay');
      var preview = document.getElementById('notePreview');

      var html = '<div class="note-preview-top">';
      html += '<button class="note-preview-close" onclick="closeNote()">✕</button>';
      html += '<span class="note-preview-author">' + escapeHtml(note.author) + '</span>';
      var d = new Date(note.createdAt);
      html += '<span class="note-preview-date">' + d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) + '</span>';
      html += '</div>';
      if (note.photo) {
        html += '<img src="' + escapeHtml(note.photo) + '" class="note-preview-img">';
      }
      if (note.content) {
        html += '<div class="note-preview-text">' + escapeHtml(note.content) + '</div>';
      }

      preview.innerHTML = html;
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeNote() {
      document.getElementById('noteOverlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    document.getElementById('noteOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeNote();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeNote();
    });

    (function() {
      var nav = document.getElementById('topNav');
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            nav.classList.toggle('scrolled', window.scrollY > 10);
            ticking = false;
          });
          ticking = true;
        }
      });
    })();
  </script>
</body>
</html>
